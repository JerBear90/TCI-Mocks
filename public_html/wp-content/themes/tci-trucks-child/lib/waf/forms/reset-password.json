{
    "args": {
        "url": "/wp-login.php?action=resetpass",
        "ajax": false,
        "method": "post",
        "messages": {
            "invalid": "Please Fill in all required fields"
        }
    },
    "login": {
        "type": "hidden"
    }, 
    "pass1": {
        "type": "password",
        "label": "New Password",
        "autocomplete": false
    },
    "pass2": {
        "type": "password",
        "label": "Confirm Password",
        "autocomplete": false
    },
    "rp_key": {
        "type": "hidden"
    },
    "submit": {
        "type": "submit",
        "container": "field-simple",
        "text": "Reset Password",
        "inputClass": "btn-success btn"
    }
}